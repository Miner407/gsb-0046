{
  "name": "multi-repo-release-impact-analyzer",
  "version": "1.2.0",
  "description": "多仓库发布变更影响分析平台",
  "main": "server.js",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "init-db": "node scripts/initDb.js",
    "reset": "node scripts/initDb.js --reset",
    "seed": "node scripts/seedData.js",
    "verify": "node scripts/verifyData.js",
    "lint": "node scripts/lint.js",
    "test-api": "node tests/apiTest.js",
    "validate": "npm run lint && npm run reset && npm run seed && npm run verify && npm run test-api"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "sql.js": "^1.14.1"
  }
}
